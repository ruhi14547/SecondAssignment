pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git "https://github.com/ruhi14547/SecondAssignment.git"
            }
        }

        stage('Publish') {
            steps {
                publishHTML([
                    allowMissing: true,
                    alwaysLinkToLastBuild: false,
                    keepAll: false,
                    reportDir: '.',
                    reportFiles: 'newhtml.html',
                    reportName: 'My html Publish'
                ])
            }
        }
    }
}
